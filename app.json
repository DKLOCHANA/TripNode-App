{
  "expo": {
    "name": "TripNode",
    "slug": "tripnode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "tripnode",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tripnode.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "We need your location to help you find places for your trips",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to help you find places for your trips"
      },
      "buildNumber": "1",
      "appleTeamId": "CLNUVH5GRA"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-apple-authentication",
      "expo-splash-screen",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4d1959ce-7965-4052-9664-75f7533cf213"
      }
    },
    "owner": "lochanaclaudedevs-organization",
    "android": {
      "package": "com.tripnode.app"
    }
  }
}
